PROJECT_NAME="FinanceManager"
PROJECT_TYPE="nextjs-typescript"
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=25
CLAUDE_OUTPUT_FORMAT="json"
ALLOWED_TOOLS="Write,Read,Edit,Glob,Grep,Bash(git *),Bash(npm *),Bash(npx *),Bash(node *),Bash(cat *),Bash(ls *),Bash(mkdir *),Bash(cp *),Bash(mv *),mcp__context7__*,Skill(gsd:*),Skill(rnv)"
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24
TASK_SOURCES="local"
CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70
PROMPT_FILE=".ralph/PROMPT.md"
AGENT_FILE=".ralph/AGENT.md"
